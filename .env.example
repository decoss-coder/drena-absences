APP_NAME="DRENA Absences"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://absences-drena.ci

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=drena_absences
DB_USERNAME=drena_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=30

MAIL_MAILER=smtp
MAIL_HOST=smtp.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@absences-drena.ci"
MAIL_FROM_NAME="${APP_NAME}"

# SMS Configuration (Orange CI API)
SMS_DRIVER=orange
SMS_ORANGE_CLIENT_ID=
SMS_ORANGE_CLIENT_SECRET=
SMS_ORANGE_SENDER=DRENA
SMS_ORANGE_API_URL=https://api.orange.com/smsmessaging/v1

# Backup
BACKUP_DISK=local
BACKUP_NOTIFICATION_EMAIL=admin@education.gouv.ci

# App Settings
ABSENCE_AUTO_ESCALATION_HOURS=48
ABSENCE_MAX_DAYS_LEVEL1=3
ABSENCE_MAX_DAYS_LEVEL2=10
DEFAULT_LOCALE=fr
TIMEZONE=Africa/Abidjan
